config {
  real_llm = true,
  allow_llm_fallback = true,
  llm_model = "claude-opus-4-7"
};

agent Guard      = FixedAgent(Guardrail);
agent Extract    = FixedAgent(Extractor);
agent Route      = FixedAgent(Router);
agent Draft      = FixedAgent(Writer);
agent Validate   = FixedAgent(Validator);
agent Critique   = FixedAgent(Critic);
agent Summarize  = FixedAgent(Summarizer);

let ticket = "Customer says their subscription was charged twice after upgrading to the Pro plan. They are frustrated and want a refund or account credit. Order ID: ORD-88421. Email: customer@example.com.";

let safety     = Guard(ticket);
let facts      = Extract(safety.output);
let route      = Route(facts.output);
let draft      = Draft({ route = route.output, facts = facts.output, original_ticket = ticket });
try {
  let draft_readable = parse_json(draft.output)
} catch err => {
  let draft_readable = draft.output
};
let validation = Validate(draft_readable);
let critique   = Critique(validation.output);
try {
  let critique_readable = parse_json(critique.output)
} catch err => {
  let critique_readable = critique.output
};
let summary    = Summarize({ route = route.output, draft = draft_readable, critique = critique_readable });

print "--- safety check ---";
print stringify(safety.output);
print "--- extracted facts ---";
print stringify(facts.output);
print "--- route ---";
print stringify(route.output);
print "--- drafted response ---";
print stringify(draft_readable);
print "--- validation ---";
print stringify(validation.output);
print "--- critique ---";
print stringify(critique_readable);
print "--- final summary ---";
print stringify(summary.output);

let result = {
  ticket = ticket,
  route = route.output,
  drafted_response = draft_readable,
  validation = validation.output,
  critique = critique_readable,
  summary = summary.output
};

print "--- final result json ---";
print stringify(result)
